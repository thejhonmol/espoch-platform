{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "providers": ["dotnet"],
      "phases": {
        "setup": {
          "nixChannel": "nixos-23_11"
        },
        "install": {
          "commands": ["dotnet restore"]
        },
        "build": {
          "commands": ["dotnet build -c Release"]
        }
      }
    }
  },
  "deploy": {
    "numInstances": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
