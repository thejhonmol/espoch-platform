{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "providers": ["dotnet"],
      "phases": {
        "setup": {
          "nixChannel": "nixos-23_11"
        },
        "install": {
          "commands": [
            "cd backend && dotnet restore"
          ]
        },
        "build": {
          "commands": [
            "cd backend && dotnet publish -c Release -o /app/publish"
          ]
        }
      },
      "start": {
        "command": "cd /app/publish && dotnet ESPOCH.API.dll"
      }
    }
  },
  "deploy": {
    "numInstances": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
